!> Test the vertical linear interpolation kernel
module lfric2lfric_vertical_linear_interp_lin_extrap_kernel_mod_test

  use constants_mod,                       only : r_def, i_def, r_single, r_double
  use get_unit_test_m3x3_q3x3x3_sizes_mod, only : get_w3_m3x3_q3x3x3_size
  use get_unit_test_m3x3_dofmap_mod,       only : get_w3_m3x3_dofmap

  use funit

  implicit none

  public:: test_all, test_all_with_extrap

contains

@Test
  subroutine test_all()

    use lfric2lfric_vertical_linear_interp_lin_extrap_kernel_mod, only: lfric2lfric_vertical_linear_interp_lin_extrap_kernel_code

    implicit none

    integer(kind=i_def)               :: nlayers
    integer(kind=i_def)               :: ncell
    integer(kind=i_def)               :: dim_space, dim_space_diff, nqp_h, nqp_v
    integer(kind=i_def)               :: source_layers
    integer(kind=i_def)               :: ndf_dest, ndf_source
    integer(kind=i_def)               :: undf_dest, undf_source
    integer(kind=i_def), allocatable  :: map_dest(:,:)
    integer(kind=i_def), allocatable  :: map_source(:,:)
    real(kind=r_single), allocatable  :: destination_field(:,:,:)
    real(kind=r_single), allocatable  :: source_field(:,:,:)
    real(kind=r_single), allocatable  :: expected_field(:,:,:)
    real(kind=r_single), allocatable  :: dest_heights(:,:,:)
    real(kind=r_single), allocatable  :: source_heights(:,:,:)
    real(kind=r_single), parameter    :: tol = 1.0e-12_r_single

    nlayers  = 3_i_def
    source_layers = 4_i_def
    call get_w3_m3x3_q3x3x3_size( ndf_source, undf_source, ncell, &
                                  dim_space, dim_space_diff,      &
                                  nqp_h, nqp_v, source_layers     )

    call get_w3_m3x3_dofmap(map_source, 4_i_def)

    call get_w3_m3x3_q3x3x3_size( ndf_dest, undf_dest, ncell, &
                                  dim_space, dim_space_diff,  &
                                  nqp_h, nqp_v, nlayers       )
    call get_w3_m3x3_dofmap(map_dest, 5_i_def)

    ! allocate
    ! allocate(destination_field(undf_dest))
    ! allocate(expected_field(undf_dest))
    ! allocate(source_field(undf_source))
    ! allocate(dest_heights(undf_dest))
    ! allocate(source_heights(undf_source))

    source_field = reshape ((/&
    1.1_r_single, 2.3_r_single, 3.2_r_single, 4.1_r_single,   &
    1.1_r_single, 2.2_r_single, 3.1_r_single, 4.4_r_single,   &
    0.7_r_single, 2.3_r_single, 2.9_r_single, 4.0_r_single,   &
    0.5_r_single, 1.5_r_single, 2.5_r_single, 3.5_r_single,   &
    1.0_r_single, 2.0_r_single, 3.0_r_single, 4.0_r_single,   &
    1.5_r_single, 2.5_r_single, 3.5_r_single, 4.5_r_single,   &
    1.4_r_single, 2.0_r_single, 3.4_r_single, 4.2_r_single,   &
    1.0_r_single, 2.4_r_single, 3.3_r_single, 4.4_r_single,   &
    1.1_r_single, 2.1_r_single, 3.3_r_single, 4.1_r_single    &
    /), (/ 4, 3, 3 /))
    expected_field = reshape ((/&
    1.7_r_single,  2.75_r_single, 3.65_r_single,   &
    1.65_r_single, 2.65_r_single, 3.75_r_single,   &
    1.5_r_single,  2.6_r_single,  3.45_r_single,   &
    1.0_r_single,  2.0_r_single,  3.0_r_single,    &
    1.5_r_single,  2.5_r_single,  3.5_r_single,    &
    2.0_r_single,  3.0_r_single,  4.0_r_single,    &
    1.7_r_single,  2.7_r_single,  3.8_r_single,    &
    1.7_r_single,  2.85_r_single, 3.85_r_single,   &
    1.6_r_single,  2.7_r_single,  3.7_r_single     &
    /), (/ 3, 3, 3 /))
    source_heights = reshape ((/&
    1.0_r_single, 2.0_r_single, 3.0_r_single, 4.0_r_single,   &
    1.0_r_single, 2.0_r_single, 3.0_r_single, 4.0_r_single,   &
    1.0_r_single, 2.0_r_single, 3.0_r_single, 4.0_r_single,   &
    1.0_r_single, 2.0_r_single, 3.0_r_single, 4.0_r_single,   &
    1.0_r_single, 2.0_r_single, 3.0_r_single, 4.0_r_single,   &
    1.0_r_single, 2.0_r_single, 3.0_r_single, 4.0_r_single,   &
    1.0_r_single, 2.0_r_single, 3.0_r_single, 4.0_r_single,   &
    1.0_r_single, 2.0_r_single, 3.0_r_single, 4.0_r_single,   &
    1.0_r_single, 2.0_r_single, 3.0_r_single, 4.0_r_single    &
    /), (/ 4, 3, 3 /))
    dest_heights = reshape ((/&
    1.5_r_single, 2.5_r_single, 3.5_r_single,   &
    1.5_r_single, 2.5_r_single, 3.5_r_single,   &
    1.5_r_single, 2.5_r_single, 3.5_r_single,   &
    1.5_r_single, 2.5_r_single, 3.5_r_single,   &
    1.5_r_single, 2.5_r_single, 3.5_r_single,   &
    1.5_r_single, 2.5_r_single, 3.5_r_single,   &
    1.5_r_single, 2.5_r_single, 3.5_r_single,   &
    1.5_r_single, 2.5_r_single, 3.5_r_single,   &
    1.5_r_single, 2.5_r_single, 3.5_r_single    &
    /), (/ 3, 3, 3 /))

    call lfric2lfric_vertical_linear_interp_lin_extrap_code_r_single(  &
                                      nlayers,                            &
                                      destination_field,                  &
                                      source_field,                       &
                                      source_layers,                      &
                                      ncell,                              &
                                      dest_heights,                       &
                                      source_heights,                     &
                                      ndf_dest,                           &
                                      undf_dest,                          &
                                      map_dest,                           &
                                      ndf_source,                         &
                                      undf_source,                        &
                                      map_source)

    @assertEqual(expected_field, destination_field, tol)

  end subroutine test_all

@Test
  subroutine test_all_with_extrap()

    use lfric2lfric_vertical_linear_interp_lin_extrap_kernel_mod, only: lfric2lfric_vertical_linear_interp_lin_extrap_kernel_code

    implicit none

    integer(kind=i_def)               :: nlayers
    integer(kind=i_def)               :: ncell
    integer(kind=i_def)               :: dim_space, dim_space_diff, nqp_h, nqp_v
    integer(kind=i_def)               :: source_layers
    integer(kind=i_def)               :: ndf_dest, ndf_source
    integer(kind=i_def)               :: undf_dest, undf_source
    integer(kind=i_def), allocatable  :: map_dest(:,:)
    integer(kind=i_def), allocatable  :: map_source(:,:)
    real(kind=r_single), allocatable  :: destination_field(:,:,:)
    real(kind=r_single), allocatable  :: source_field(:,:,:)
    real(kind=r_single), allocatable  :: expected_field(:,:,:)
    real(kind=r_single), allocatable  :: dest_heights(:,:,:)
    real(kind=r_single), allocatable  :: source_heights(:,:,:)
    real(kind=r_single), parameter    :: tol = 1.0e-12_r_single

    nlayers  = 5_i_def
    source_layers = 4_i_def
    call get_w3_m3x3_q3x3x3_size( ndf_source, undf_source, ncell, &
                                  dim_space, dim_space_diff,      &
                                  nqp_h, nqp_v, source_layers     )

    call get_w3_m3x3_dofmap(map_source, 4_i_def)

    call get_w3_m3x3_q3x3x3_size( ndf_dest, undf_dest, ncell, &
                                  dim_space, dim_space_diff,  &
                                  nqp_h, nqp_v, nlayers       )
    call get_w3_m3x3_dofmap(map_dest, 5_i_def)

    ! allocate
    ! allocate(destination_field(undf_dest))
    ! allocate(expected_field(undf_dest))
    ! allocate(source_field(undf_source))
    ! allocate(dest_heights(undf_dest))
    ! allocate(source_heights(undf_source))

    source_field = reshape ((/&
    1.1_r_single, 2.3_r_single, 3.2_r_single, 4.1_r_single,   &
    1.1_r_single, 2.2_r_single, 3.1_r_single, 4.4_r_single,   &
    0.7_r_single, 2.3_r_single, 2.9_r_single, 4.0_r_single,   &
    0.5_r_single, 1.5_r_single, 2.5_r_single, 3.5_r_single,   &
    1.0_r_single, 2.0_r_single, 3.0_r_single, 4.0_r_single,   &
    1.5_r_single, 2.5_r_single, 3.5_r_single, 4.5_r_single,   &
    1.4_r_single, 2.0_r_single, 3.4_r_single, 4.2_r_single,   &
    1.0_r_single, 2.4_r_single, 3.3_r_single, 4.4_r_single,   &
    1.1_r_single, 2.1_r_single, 3.3_r_single, 4.1_r_single    &
    /), (/ 4, 3, 3 /))
    expected_field = reshape ((/&
    0.5_r_single,  1.7_r_single,  2.75_r_single, 3.65_r_single, 4.55_r_single, &
    0.55_r_single, 1.65_r_single, 2.65_r_single, 3.75_r_single, 5.05_r_single, &
    -0.1_r_single, 1.5_r_single,  2.6_r_single,  3.45_r_single, 4.55_r_single, &
    0.0_r_single,  1.0_r_single,  2.0_r_single,  3.0_r_single,  4.0_r_single,  &
    0.5_r_single,  1.5_r_single,  2.5_r_single,  3.5_r_single,  4.5_r_single,  &
    1.0_r_single,  2.0_r_single,  3.0_r_single,  4.0_r_single,  5.0_r_single,  &
    1.1_r_single,  1.7_r_single,  2.7_r_single,  3.8_r_single,  4.6_r_single,  &
    0.3_r_single,  1.7_r_single,  2.85_r_single, 3.85_r_single, 4.95_r_single, &
    0.6_r_single,  1.6_r_single,  2.7_r_single,  3.7_r_single,  4.5_r_single   &
    /), (/ 5, 3, 3 /))
    source_heights = reshape ((/&
    1.0_r_single, 2.0_r_single, 3.0_r_single, 4.0_r_single,   &
    1.0_r_single, 2.0_r_single, 3.0_r_single, 4.0_r_single,   &
    1.0_r_single, 2.0_r_single, 3.0_r_single, 4.0_r_single,   &
    1.0_r_single, 2.0_r_single, 3.0_r_single, 4.0_r_single,   &
    1.0_r_single, 2.0_r_single, 3.0_r_single, 4.0_r_single,   &
    1.0_r_single, 2.0_r_single, 3.0_r_single, 4.0_r_single,   &
    1.0_r_single, 2.0_r_single, 3.0_r_single, 4.0_r_single,   &
    1.0_r_single, 2.0_r_single, 3.0_r_single, 4.0_r_single,   &
    1.0_r_single, 2.0_r_single, 3.0_r_single, 4.0_r_single    &
    /), (/ 4, 3, 3 /))
    dest_heights = reshape ((/&
    0.5_r_single,  1.5_r_single, 2.5_r_single, 3.5_r_single,  4.5_r_single,   &
    0.5_r_single,  1.5_r_single, 2.5_r_single, 3.5_r_single,  4.5_r_single,   &
    0.5_r_single,  1.5_r_single, 2.5_r_single, 3.5_r_single,  4.5_r_single,   &
    0.5_r_single,  1.5_r_single, 2.5_r_single, 3.5_r_single,  4.5_r_single,   &
    0.5_r_single,  1.5_r_single, 2.5_r_single, 3.5_r_single,  4.5_r_single,   &
    0.5_r_single,  1.5_r_single, 2.5_r_single, 3.5_r_single,  4.5_r_single,   &
    0.5_r_single,  1.5_r_single, 2.5_r_single, 3.5_r_single,  4.5_r_single,   &
    0.5_r_single,  1.5_r_single, 2.5_r_single, 3.5_r_single,  4.5_r_single,   &
    0.5_r_single,  1.5_r_single, 2.5_r_single, 3.5_r_single,  4.5_r_single    &
    /), (/ 5, 3, 3 /))

    call lfric2lfric_vertical_linear_interp_lin_extrap_code_r_single(  &
                                      nlayers,                            &
                                      destination_field,                  &
                                      source_field,                       &
                                      source_layers,                      &
                                      ncell,                              &
                                      dest_heights,                       &
                                      source_heights,                     &
                                      ndf_dest,                           &
                                      undf_dest,                          &
                                      map_dest,                           &
                                      ndf_source,                         &
                                      undf_source,                        &
                                      map_source)

    @assertEqual(expected_field, destination_field, tol)

  end subroutine test_all_with_extrap

end module lfric2lfric_vertical_linear_interp_lin_extrap_kernel_mod_test
